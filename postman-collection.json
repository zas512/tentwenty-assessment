                "prizes"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "description": "Admin only. List all users.",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user"
              ]
            }
          }
        },
        {
          "name": "Update User Role",
          "description": "Admin only. Update a user's role to ADMIN, VIP, USER, or GUEST.",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/{{userId}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "{{userId}}",
                "role"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"VIP\"\n}"
            }
          }
        },
        {
          "name": "Create Contest",
          "description": "Admin only. Create a contest.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/contest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contest"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Sample Contest\",\n  \"description\": \"A demo contest\",\n  \"access\": \"NORMAL\",\n  \"startsAt\": \"2026-06-30T10:00:00.000Z\",\n  \"endsAt\": \"2026-06-30T12:00:00.000Z\",\n  \"prizeTitle\": \"Gift Card\",\n  \"prizeDesc\": \"Winner prize description\"\n}"
            }
          }
        },
        {
          "name": "Update Contest",
          "description": "Admin only. Update contest fields.",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/contest/{{contestId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contest",
                "{{contestId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        },
        {
          "name": "Delete Contest",
          "description": "Admin only. Delete a contest.",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/contest/{{contestId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contest",
                "{{contestId}}"
              ]
            }
          }
        },
        {
          "name": "Add Question",
          "description": "Admin only. Add a question to a contest.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/contest/{{contestId}}/questions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contest",
                "{{contestId}}",
                "questions"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Which option is correct?\",\n  \"type\": \"SINGLE_SELECT\",\n  \"order\": 1,\n  \"points\": 5,\n  \"options\": [\n    { \"text\": \"Option A\", \"isCorrect\": true, \"order\": 1 },\n    { \"text\": \"Option B\", \"isCorrect\": false, \"order\": 2 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Update Question",
          "description": "Admin only. Update question text, points, order, or options.",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/contest/{{contestId}}/questions/{{questionId1}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contest",
                "{{contestId}}",
                "questions",
                "{{questionId1}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Updated question text\",\n  \"points\": 10\n}"
            }
          }
        },
        {
          "name": "Delete Question",
          "description": "Admin only. Delete a question from a contest.",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/contest/{{contestId}}/questions/{{questionId1}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contest",
                "{{contestId}}",
                "questions",
                "{{questionId1}}"
              ]
            }
          }
        }
