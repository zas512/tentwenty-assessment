{
  "info": {
    "_postman_id": "8ff8ecce-1ee9-4858-a145-46d5f6e4f321",
    "name": "TenTwenty Test APIs",
    "description": "Postman collection for authenticated Guest, User, VIP and Admin contest flows. Import with cookies enabled and use the seeded contest/question IDs or your own local data.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "description": "Register a normal user account.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@example.com\",\n  \"username\": \"user1\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "description": "Log in a registered user and store auth cookies in Postman.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Guest Login",
          "description": "Create an authenticated guest session. This is still a protected authenticated flow.",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/guest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "guest"
              ]
            }
          }
        },
        {
          "name": "Get My Profile",
          "description": "Fetch the current authenticated user from the access cookie.",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "description": "Exchange the refresh cookie for a new access cookie.",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "description": "Clear the auth cookies.",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Contests",
      "item": [
        {
          "name": "Get Contests (Authenticated)",
          "description": "List contests visible to the authenticated role.",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/contest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contest"
              ]
            }
          }
        },
        {
          "name": "Get Contest By Id (Authenticated)",
          "description": "Fetch a single contest. Draft contests are admin-only and VIP contests are restricted to admin and VIP roles.",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/contest/{{contestId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contest",
                "{{contestId}}"
              ]
            }
          }
        },
        {
          "name": "Get Contest Questions",
          "description": "Fetch contest questions for the authenticated role.",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/contest/{{contestId}}/questions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contest",
                "{{contestId}}",
                "questions"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Participation",
      "item": [
        {
          "name": "Join Contest",
          "description": "Join a contest before submitting answers.",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/participation/{{contestId}}/join",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "participation",
                "{{contestId}}",
                "join"
              ]
            }
          }
        },
        {
          "name": "Submit Contest Answers",
          "description": "Submit answers and receive the calculated score.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/participation/{{contestId}}/submit",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "participation",
                "{{contestId}}",
                "submit"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": [\n    {\n      \"questionId\": \"{{questionId1}}\",\n      \"optionIds\": [\"{{optionId1}}\"]\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get Leaderboard (Authenticated)",
          "description": "Fetch leaderboard entries for a contest. Supports optional limit and offset query params.",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/participation/{{contestId}}/leaderboard?limit=50&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "participation",
                "{{contestId}}",
                "leaderboard"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
